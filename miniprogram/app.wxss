/* 全局样式 */
page {
  background: #f4f5f7;
  font-size: 28rpx;
  color: #1f2329;
}
.container {
  padding: 24rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.btn-primary {
  background: #1f6feb;
  color: #fff;
  border-radius: 12rpx;
}
.btn-line {
  border: 1rpx solid #1f6feb;
  color: #1f6feb;
  background: #fff;
  border-radius: 12rpx;
}
.muted { color: #8a9099; font-size: 24rpx; }
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
}
.level-blue { background: #1f6feb; }
.level-yellow { background: #e3a008; }
.level-orange { background: #f56300; }
.level-red { background: #e5484d; }
