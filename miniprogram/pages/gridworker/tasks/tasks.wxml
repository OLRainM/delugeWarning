<view class="container">
  <view style="display:flex;gap:16rpx;margin-bottom:16rpx;">
    <view class="{{status===''?'btn-primary':'btn-line'}}" style="flex:1;text-align:center;padding:16rpx;" data-s="" bindtap="filter">全部</view>
    <view class="{{status==='pending'?'btn-primary':'btn-line'}}" style="flex:1;text-align:center;padding:16rpx;" data-s="pending" bindtap="filter">待确认</view>
    <view class="{{status==='handling'?'btn-primary':'btn-line'}}" style="flex:1;text-align:center;padding:16rpx;" data-s="handling" bindtap="filter">处置中</view>
    <view class="{{status==='finished'?'btn-primary':'btn-line'}}" style="flex:1;text-align:center;padding:16rpx;" data-s="finished" bindtap="filter">已完成</view>
  </view>

  <view class="card" wx:if="{{tasks.length===0}}"><view class="muted" style="text-align:center;">暂无任务</view></view>
  <view class="card" wx:for="{{tasks}}" wx:key="id" bindtap="open" data-id="{{item.id}}">
    <view style="display:flex;justify-content:space-between;">
      <text>任务 #{{item.id}}（预警 #{{item.alert_id}}）</text>
      <text class="muted">{{item.status}}</text>
    </view>
    <view class="muted" style="margin-top:8rpx;">{{item.handle_remark || '点击处理'}}</view>
  </view>

  <view class="nav-grid">
    <view class="nav-item" bindtap="goAlerts">预警复核</view>
    <view class="nav-item" bindtap="goMine">我的</view>
  </view>
</view>
